# ═══════════════════════════════════════════════
# UNIRABBIT — DeepClaudeTraderBot
# Copy to .env and fill in your API keys.
# ═══════════════════════════════════════════════

BINANCE_API_KEY=your_key_here
BINANCE_API_SECRET=your_secret_here

# ═══ SAFETY ═══
DRY_RUN=1
FORCE_START=0

# ═══ RISK ═══
RISK_PCT=2.0
MAX_OPEN_POSITIONS=3
MAX_CONCURRENT_POS_HARD=3
TOTAL_RISK_BUDGET=18.0
MAX_RISK_PER_TRADE=2.0
LEVERAGE=3

# ═══ STRATEGY — DAY TRADING ═══
MIN_SIGNAL_SCORE=18
MIN_SIGNAL_STRENGTH=0.25
MIN_VOLUME_24H=100000000
COOLDOWN_SEC=300
COOLDOWN_SAME_SYMBOL=900
MAX_ENTRIES_PER_MIN=4

# ═══ EXITS — aggressive R-based trailing ═══
MIN_STOP_DISTANCE_PCT=2.5
USE_TRAILING_ENGINE=1
MAX_POSITION_AGE_SEC=28800
TRAIL_ENGINE_START_BUFFER_R=0.3
TRAIL_ENGINE_BREAK_EVEN_R=1.0
TRAIL_ENGINE_BE_BUFFER_R=0.15
TRAIL_ENGINE_LOCK_R_LEVEL=1.5
TRAIL_ENGINE_LOCK_AMOUNT_R=0.75
TRAIL_ENGINE_RUNNER_START_R=2.0
TRAIL_ENGINE_RUNNER_TRAIL_DISTANCE_R=0.5
TRAIL_ENGINE_PARTIAL_1_SIZE=0.50
TRAIL_ENGINE_PARTIAL_2_SIZE=0.25

# ═══ KILL SWITCH ═══
MAX_DRAWDOWN_PCT=5
DRAWDOWN_CIRCUIT_BREAKER_ENABLED=1

# ═══ FILTERS — trend-friendly ═══
ADX_TREND_GATE_ENABLED=0
ER_FILTER_ENABLED=0
MOMENTUM_15M_ENABLED=0
BTC_CHOP_THRESHOLD=0.2

# ═══ UI ═══
USE_RICH_UI=0
UI_MODE=none
