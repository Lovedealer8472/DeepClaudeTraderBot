# Binance Futures API Credentials
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Exchange Settings
EXCHANGE=binance_futures
BINANCE_TESTNET=0

# Trading Mode
DRY_RUN=1

# Account Settings
ACCOUNT_BAL=250
LEVERAGE=5

# UI Settings
USE_RICH_UI=true

# Risk Management
RISK_PCT=0.5
MAX_OPEN_POSITIONS=12
MAX_CONCURRENT_POS=10

# Signal Settings
MIN_SIGNAL_SCORE=60
MIN_SIGNAL_STRENGTH=0.60

# Optional: LLM Control (leave empty if not using)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
PERPLEXITY_API_KEY=

